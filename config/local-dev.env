# Local Development Configuration (Parquet-based)

# Data paths
DATA_PATH=/My Data/Academic/GaTech/IHI/vanguard-health/local_testing/data
BRONZE_PATH=/My Data/Academic/GaTech/IHI/vanguard-health/local_testing/data/bronze
SILVER_PATH=/My Data/Academic/GaTech/IHI/vanguard-health/local_testing/data/silver

# Synthea FHIR API
SYNTHEA_API_URL=https://r4.smarthealthit.org
SYNTHEA_API_KEY=local-dev-key
SYNTHEA_FETCH_INTERVAL_HOURS=6

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=30017
MONGODB_USER=root
MONGODB_PASSWORD=mongopass
MONGODB_DB=vanguard_metadata
MONGODB_URI=mongodb://root:mongopass@localhost:30017/?authSource=admin

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Firebase
FIREBASE_PROJECT_ID=vanguard-health
FIREBASE_CREDENTIALS_PATH=/app/config/firebase-creds.json

# Spark
SPARK_MASTER=local[4]
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=2g

# Logging
LOG_LEVEL=DEBUG
LOG_FILE=/app/logs/vanguard.log

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_FETCH_TASKS=fhir-fetch-tasks
KAFKA_CONSUMER_GROUP=fhir-workers
KAFKA_MAX_WORKERS=4

# Feature flags
ENABLE_REDIS_CACHING=false
ENABLE_FIREBASE_SYNC=true
ENABLE_KAFKA_WORKER=true
TEST_MODE=false
