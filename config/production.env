# Production Configuration (Cloud-based Hudi)

# Data paths (cloud storage)
DATA_PATH=s3://vanguard-health-prod/data
BRONZE_PATH=s3://vanguard-health-prod/data/bronze
SILVER_PATH=s3://vanguard-health-prod/data/silver

# Synthea FHIR API
SYNTHEA_API_URL=https://synthea-fhir-server.mitre.org/fhir
SYNTHEA_API_KEY=${SYNTHEA_API_KEY}
SYNTHEA_FETCH_INTERVAL_HOURS=6

# MongoDB (Cloud Atlas)
MONGODB_URI=${MONGODB_URI}
MONGODB_DB=vanguard_metadata

# Redis (elasticache/memorystore)
REDIS_HOST=${REDIS_HOST}
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=${REDIS_PASSWORD}

# Firebase
FIREBASE_PROJECT_ID=vanguard-health-prod
FIREBASE_CREDENTIALS_PATH=/app/config/firebase-creds.json

# Spark on Kubernetes
SPARK_MASTER=k8s://https://kubernetes.default.svc.cluster.local:443
SPARK_EXECUTOR_MEMORY=4g
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_INSTANCES=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/vanguard/vanguard.log

# Kafka (MSK or similar)
KAFKA_BOOTSTRAP_SERVERS=${KAFKA_BOOTSTRAP_SERVERS}
KAFKA_TOPIC_FETCH_TASKS=fhir-fetch-tasks
KAFKA_CONSUMER_GROUP=fhir-workers-prod
KAFKA_MAX_WORKERS=8

# Feature flags
ENABLE_REDIS_CACHING=true
ENABLE_FIREBASE_SYNC=true
ENABLE_KAFKA_WORKER=true
TEST_MODE=false

# Cloud configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
