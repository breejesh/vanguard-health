metastore_db/     # Default Derby metastore
derby.log         # Default Derby log file
logs/             # General log directory
work/             # Spark's default work directory for standalone mode
.spark/           # User-specific spark directory
target/           # Common build output directory
spark.egg-info/   # PySpark packaging info
tmp/              # Temporary files

